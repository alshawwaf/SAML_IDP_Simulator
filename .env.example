# ===========================================
# SAML IDP Simulator - Environment Configuration
# ===========================================
# Copy this file to .env and customize values
# All values shown are defaults (used if not set)

# Server Configuration
IDP_PORT=9001
IDP_HOST=0.0.0.0
ENABLE_SSL=false
FLASK_DEBUG=true

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secure-random-key-here
ADMIN_USERNAME=admin@cpdemo.ca
ADMIN_PASSWORD=Cpwins!1@2026

# IDP Identity
IDP_ENTITY_ID=https://idp.simulator
SSO_SERVICE_URL=http://localhost:9001/sso

# Certificate Paths (relative to app root)
CERT_PATH=app/certs/idp-cert.pem
KEY_PATH=app/certs/idp-key.pem

# Optional: Error Monitoring
# GLITCHTIP_DSN=your-glitchtip-dsn-here

# ===========================================
# SCIM 2.0 (Optional — disabled by default)
# ===========================================
# When ENABLE_SCIM=false the SAML flow is unaffected and SCIM tables/routes
# are not created or registered.
ENABLE_SCIM=false
SCIM_BASE_PATH=/scim/v2

# Required when ENABLE_SCIM=true and you store outbound bearer tokens (Phase 3+).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SCIM_ENCRYPTION_KEY=

# Phase 5 (optional): auto-push admin user CRUD to enabled SCIM targets.
SCIM_PUSH_ON_USER_CHANGE=false
