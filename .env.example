# ===========================================
# SAML IDP Simulator - Environment Configuration
# ===========================================
# Copy this file to .env and customize values
# All values shown are defaults (used if not set)

# Server Configuration
IDP_PORT=9001
IDP_HOST=0.0.0.0
ENABLE_SSL=false
FLASK_DEBUG=true

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secure-random-key-here
ADMIN_USERNAME=admin@cpdemo.ca
ADMIN_PASSWORD=Cpwins!1@2026

# IDP Identity
IDP_ENTITY_ID=https://idp.simulator
SSO_SERVICE_URL=http://localhost:9001/sso

# Certificate Paths (relative to app root)
CERT_PATH=app/certs/idp-cert.pem
KEY_PATH=app/certs/idp-key.pem

# Optional: Error Monitoring
# GLITCHTIP_DSN=your-glitchtip-dsn-here

# ===========================================
# SCIM 2.0 (Optional — disabled by default)
# ===========================================
# Set ENABLE_SCIM=true and that's it. On first boot the simulator will:
#   - derive the token-encryption key from SECRET_KEY (no manual key needed)
#   - auto-generate a default inbound bearer token, log it, and write it to
#     data/.scim-bootstrap-token for you to copy
ENABLE_SCIM=false

# Advanced overrides (defaults shown — leave commented out unless you need them):
# SCIM_BASE_PATH=/scim/v2
# SCIM_ENCRYPTION_KEY=        # set explicitly to decouple from SECRET_KEY
# SCIM_PUSH_ON_USER_CHANGE=false   # auto-push admin user CRUD to enabled SCIM targets
